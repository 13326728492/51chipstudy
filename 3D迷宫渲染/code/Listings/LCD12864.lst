 153          void LCD_DrawPixel(unsigned char x,unsigned char y)
 154          {
 155   1        
 156   1        unsigned char H,L;
 157   1        unsigned char pos;
 158   1      
 159   1        
 160   1        pos = 15 - (x%16);
 161   1      
 162   1        if(y<32)
 163   1        {
 164   2          LCD_Write_Cmd(0x80+y);
 165   2          _nop_();
 166   2          LCD_Write_Cmd(0x80+(x/16));
 167   2          _nop_();_nop_();
 168   2          LCD_Read_Data();
 169   2          H = LCD_Read_Data();
 170   2          L = LCD_Read_Data();
 171   2          if(pos >= 8)
 172   2          {
 173   3            H |= 1 << (pos-8);
 174   3          }
 175   2          else
 176   2          {
 177   3            L |= 1 << pos;
 178   3          }
C51 COMPILER V9.55   LCD12864                                                              04/16/2026 16:54:56 PAGE 4   

 179   2          
 180   2          LCD_Write_Cmd(0x80+y);
 181   2          _nop_();
 182   2          LCD_Write_Cmd(0x80+(x/16));
 183   2          _nop_();
 184   2          LCD_Read_Data();
 185   2          LCD_Write_Data(H);
 186   2          LCD_Write_Data(L);
 187   2          _nop_();
 188   2        }
 189   1        else if(y>=32)
 190   1        {
 191   2          LCD_Write_Cmd(0x80+y-32);
 192   2          _nop_();
 193   2          LCD_Write_Cmd(0x88+(x/16));
 194   2          _nop_();
 195   2          LCD_Read_Data();
 196   2          H = LCD_Read_Data();
 197   2          L = LCD_Read_Data();
 198   2          
 199   2          if(pos >= 8)
 200   2          {
 201   3            H |= 1 << (pos -8);
 202   3          }
 203   2          else
 204   2          {
 205   3            L |= 1 << pos;
 206   3          }
 207   2          
 208   2          LCD_Write_Cmd(0x80+y-32);
 209   2          _nop_();
 210   2          LCD_Write_Cmd(0x88+(x/16));
 211   2          _nop_();
 212   2          LCD_Write_Data(H);
 213   2        
 214   2          LCD_Write_Data(L);
 215   2          _nop_();
