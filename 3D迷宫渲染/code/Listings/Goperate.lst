  85          void rendertest2(unsigned char map[8][8])
  86          {
  87   1        unsigned char x;
  88   1        int gx_hit;
  89   1        int gy_hit;
  90   1        for(x = 0;x<128;x++)
  91   1        {
  92   2          cast_ray(x,map);
  93   2          gx_hit = ray_x/4;
  94   2          gy_hit = ray_y/4;
  95   2          lineHeight = (64*renderCofficient2)/distance;
  96   2          drawStart = 12 - lineHeight/4 ;
  97   2          drawEnd = drawStart + lineHeight;
  98   2          
  99   2          if(drawStart < 0)drawStart = 0;
 100   2          if(drawEnd >= 64)drawEnd = 63;
 101   2          
 102   2          if(map[gy_hit][gx_hit])
 103   2          {
 104   3            LCD_Draw_Vertical_Line(x,drawStart,drawEnd);
 105   3          }
 106   2          else if(map[gy_hit][gx_hit] == 2)
 107   2          {
 108   3            int mid = (drawStart + drawEnd)/2;
 109   3            LCD_Draw_Vertical_Line(x,drawStart,mid-4);
 110   3            LCD_Draw_Vertical_Line(x,mid+4,drawEnd);
 111   3          }
 112   2        }
 113   1      }
